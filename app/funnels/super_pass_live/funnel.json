{
  "funnel_id": "super_pass_live",
  "name": "Super Pass Live",
  "enabled": true,

  "email": {
    "subject_prefix": "Super Pass Live Funnel",
    "subscribers": [
      "saksham.gupta@classplus.co"
    ],
    "send_always_summary": true
  },

  "sources": {
    "webengage": {
      "enabled": true,
      "payload_template": {
        "version": "V2",
        "over": {
          "type": "date",
          "name": "hour",
          "attr-category": "system"
        },
        "events": [
          {
            "name": "user_session_started",
            "category": "system",
            "series": "A",
            "displayName": "Session Started",
            "aggregation": {
              "criteria": null,
              "metric": "UNIQUES"
            }
          },
          {
            "name": "supercoaching_goal_page_visited",
            "category": "application",
            "filters": {
                "logicalOperator": "AND",
                "expressions": [
                    {
                        "attribute": "goalID",
                        "attributeCategory": "custom",
                        "values": [
                            "685e851a620511f4ba002ff6"
                        ],
                        "operator": "EQ",
                        "type": "string"
                    }
                ]
            },
            "series": "B",
            "displayName": "supercoaching_goal_page_visited",
            "aggregation": {
              "criteria": null,
              "metric": "UNIQUES"
            }
          }
        ]
      }
    },

    "redash": {
    "enabled": true,
    "base_url": "https://data.testbook.com",
    "query_id": 22065,
    "user_api_key_env": "REDASH_TESTBOOK_USER_API_KEY",
    "max_age_seconds": 900,
    "freshness_tolerance_minutes": 120,
    "timeout_seconds": 90,
    "time_column": "Date"
    }
  },

  "steps": [
    {
      "name": "Sessions",
      "source": "webengage",
      "source_key": "Session Started"
    },
    {
      "name": "Goal Page Visited",
      "source": "webengage",
      "source_key": "supercoaching_goal_page_visited"
    },
    {
      "name": "Orders Created",
      "source": "redash",
      "source_key": "TotalTransactions"
    },
    {
    "name": "Orders Paid",
    "source": "redash",
    "source_key": "SuccessTransactions"
    }
  ],

  "health_config": {
    "comparison_days": 10,

    "default_drop_threshold_pct": 5,
    "default_min_baseline_count": 1,
    "default_min_history_points": 7,

    "default_ratio_drop_threshold_pct": 10,
    "default_min_ratio_history_points": 7,

    "events": {
      "Sessions": {
        "drop_threshold_pct": 8,
        "min_baseline_count": 5000,
        "min_history_points": 7
      },
      "Goal Page Visited": {
        "drop_threshold_pct": 10,
        "min_baseline_count": 1000,
        "min_history_points": 7
      },
      "Orders Created": {
        "drop_threshold_pct": 12,
        "min_baseline_count": 50,
        "min_history_points": 7
      },
      "Orders Paid": {
        "drop_threshold_pct": 15,
        "min_baseline_count": 20,
        "min_history_points": 7
      }
    },

    "ratios": {
      "Sessions->Goal Page Visited": {
        "drop_threshold_pct": 15,
        "min_history_points": 7
      },
      "Goal Page Visited->Orders Created": {
        "drop_threshold_pct": 12,
        "min_history_points": 7
      },
      "Orders Created->Orders Paid": {
        "drop_threshold_pct": 10,
        "min_history_points": 7
      }
    }
  }
}