{
  "funnel_id": "super_pass_live_trial",
  "name": "Super Pass Live - Trial",
  "enabled": true,
  "email": {
    "subject_prefix": "Super Pass Live (Trial) Funnel",
    "subscribers": [
      "saksham.gupta@classplus.co"
    ],
    "notify_on": "alert_only"
  },
  "sources": {
    "webengage": {
      "enabled": true,
      "payload_template": {
        "version": "V2",
        "over": {
          "type": "date",
          "name": "hour",
          "attr-category": "system"
        },
        "events": [
          {
            "name": "user_session_started",
            "category": "system",
            "filters": {
              "logicalOperator": "AND",
              "expressions": [
                {
                  "attribute": "app_id",
                  "attributeCategory": "system",
                  "values": [
                    "com.testbook.tbapp"
                  ],
                  "operator": "EQ",
                  "type": "string"
                }
              ]
            },
            "series": "A",
            "displayName": "Session Started",
            "aggregation": {
              "criteria": null,
              "metric": "UNIQUES"
            }
          },
          {
            "name": "supercoaching_goal_page_visited",
            "category": "application",
            "filters": {
              "logicalOperator": "AND",
              "expressions": [
                {
                  "attribute": "goalID",
                  "attributeCategory": "custom",
                  "values": [
                    "685e851a620511f4ba002ff6"
                  ],
                  "operator": "IN",
                  "type": "string"
                }
              ]
            },
            "series": "B",
            "displayName": "supercoaching_goal_page_visited",
            "aggregation": {
              "criteria": null,
              "metric": "UNIQUES"
            }
          }
        ]
      }
    },
    "redash": {
      "enabled": true,
      "base_url": "https://data.testbook.com",
      "query_id": 22065,
      "user_api_key_env": "REDASH_TESTBOOK_USER_API_KEY",
      "max_age_seconds": 900,
      "freshness_tolerance_minutes": 120,
      "timeout_seconds": 90,
      "time_column": "Date"
    }
  },
  "steps": [
    {
      "name": "Sessions",
      "source": "webengage",
      "source_key": "Session Started"
    },
    {
      "name": "Goal Page Visited",
      "source": "webengage",
      "source_key": "supercoaching_goal_page_visited"
    },
    {
      "name": "Orders Created",
      "source": "redash",
      "source_key": "TotalTransactions"
    },
    {
      "name": "Successful Orders",
      "source": "redash",
      "source_key": "SuccessTransactions"
    }
  ],
  "health_config": {
    "mode": "benchmark",
    "alert_mode": "ratios_only",
    "events": {
      "Sessions": {
        "benchmark_value": 134607,
        "drop_threshold_pct": 8
      },
      "Goal Page Visited": {
        "benchmark_value": 33649,
        "drop_threshold_pct": 10
      },
      "Orders Created": {
        "benchmark_value": 1165,
        "drop_threshold_pct": 12
      },
      "Successful Orders": {
        "benchmark_value": 236,
        "drop_threshold_pct": 15
      }
    },
    "ratios": {
      "Sessions->Goal Page Visited": {
        "benchmark_pct": 44,
        "drop_threshold_pct": 3
      },
      "Goal Page Visited->Orders Created": {
        "benchmark_pct": 4,
        "drop_threshold_pct": 1
      },
      "Orders Created->Successful Orders": {
        "benchmark_pct": 20,
        "drop_threshold_pct": 2
      }
    }
  }
}